<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ocean_gradient">

    <!-- Animated wave background -->
    <com.watermonitor.app.ui.views.OceanWaveView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Pump A Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPumpA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/control_card_height"
                android:layout_marginBottom="14dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgPumpAIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_pump"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <LinearLayout
                        android:id="@+id/layoutPumpALabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/imgPumpAIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchPumpA">

                        <TextView
                            style="@style/Style.WaterMonitor.ControlLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/control_pump_a" />

                        <TextView
                            android:id="@+id/tvPumpAState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OFF"
                            android:textSize="13sp"
                            android:textColor="@color/status_grey"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchPumpA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pump B Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPumpB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/control_card_height"
                android:layout_marginBottom="14dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgPumpBIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_pump"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <LinearLayout
                        android:id="@+id/layoutPumpBLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/imgPumpBIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchPumpB">

                        <TextView
                            style="@style/Style.WaterMonitor.ControlLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/control_pump_b" />

                        <TextView
                            android:id="@+id/tvPumpBState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OFF"
                            android:textSize="13sp"
                            android:textColor="@color/status_grey"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchPumpB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Main Valve Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardValveMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/control_card_height"
                android:layout_marginBottom="14dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgValveMainIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_tank"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <LinearLayout
                        android:id="@+id/layoutValveMainLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/imgValveMainIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchValveMain">

                        <TextView
                            style="@style/Style.WaterMonitor.ControlLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/control_valve_main" />

                        <TextView
                            android:id="@+id/tvValveMainState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ON"
                            android:textSize="13sp"
                            android:textColor="@color/status_green"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchValveMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bypass Valve Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardValveBypass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/control_card_height"
                android:layout_marginBottom="20dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgValveBypassIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_wave"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <LinearLayout
                        android:id="@+id/layoutValveBypassLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/imgValveBypassIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchValveBypass">

                        <TextView
                            style="@style/Style.WaterMonitor.ControlLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/control_valve_bypass" />

                        <TextView
                            android:id="@+id/tvValveBypassState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OFF"
                            android:textSize="13sp"
                            android:textColor="@color/status_grey"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchValveBypass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- System Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSystemStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/system_label"
                        android:textSize="16sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvSystemStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/system_standby"
                        android:textSize="16sp"
                        android:textColor="@color/status_grey"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginStart="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
