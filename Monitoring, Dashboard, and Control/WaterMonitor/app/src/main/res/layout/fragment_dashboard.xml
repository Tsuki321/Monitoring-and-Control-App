<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ocean_gradient">

    <!-- Animated wave background -->
    <com.watermonitor.app.ui.views.OceanWaveView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Tank Level Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tank_level_label"
                        style="@style/Style.WaterMonitor.SensorTitle"
                        android:layout_marginBottom="12dp" />

                    <com.watermonitor.app.ui.views.WaterTankView
                        android:id="@+id/waterTankView"
                        android:layout_width="@dimen/tank_width"
                        android:layout_height="@dimen/tank_height" />

                    <TextView
                        android:id="@+id/tvTankPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tank: 65%"
                        android:textSize="14sp"
                        android:textColor="@color/text_medium"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- System Status Card (Pumps) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSystemStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pump Status"
                        style="@style/Style.WaterMonitor.SensorTitle"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_pump"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvPumpAStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pump A: OFF"
                            android:textSize="15sp"
                            android:textColor="@color/status_grey"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvPumpBStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pump B: OFF"
                            android:textSize="15sp"
                            android:textColor="@color/status_grey"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sensor Online Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSensorStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sensor_status_title"
                        style="@style/Style.WaterMonitor.SensorTitle"
                        android:layout_marginBottom="12dp" />

                    <!-- pH row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:id="@+id/dotPh"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_status_dot"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/tvPhOnline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="pH: Online"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark" />

                    </LinearLayout>

                    <!-- TDS row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:id="@+id/dotTds"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_status_dot"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/tvTdsOnline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TDS: Online"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark" />

                    </LinearLayout>

                    <!-- Turbidity row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/dotTurbidity"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_status_dot"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/tvTurbidityOnline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Turbidity: Online"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Navigation Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoMonitoring"
                style="@style/Style.WaterMonitor.NavButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:alpha="0"
                android:text="@string/btn_go_monitoring"
                app:icon="@drawable/ic_wave"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoControl"
                style="@style/Style.WaterMonitor.NavButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:alpha="0"
                android:text="@string/btn_go_control"
                app:icon="@drawable/ic_pump"
                app:iconGravity="textStart" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
