<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ocean_gradient">

    <!-- Full-screen animated wave background -->
    <com.watermonitor.app.ui.views.OceanWaveView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Ornate frame overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:foreground="@drawable/bg_monitoring_frame" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- pH Sensor Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPh"
                style="@style/Style.WaterMonitor.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/tvPhTitle"
                        style="@style/Style.WaterMonitor.SensorTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/sensor_ph"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/imgPhIcon" />

                    <ImageView
                        android:id="@+id/imgPhIcon"
                        android:layout_width="@dimen/sensor_icon_size"
                        android:layout_height="@dimen/sensor_icon_size"
                        android:src="@drawable/ic_ph_tube"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvPhValue"
                        style="@style/Style.WaterMonitor.SensorValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="7.00"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPhTitle"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvPhUnit"
                        style="@style/Style.WaterMonitor.SensorUnit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/unit_ph"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPhValue" />

                    <TextView
                        android:id="@+id/tvPhStatus"
                        style="@style/Style.WaterMonitor.StatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Status: Neutral"
                        android:textColor="@color/status_green"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPhUnit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TDS Sensor Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTds"
                style="@style/Style.WaterMonitor.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/tvTdsTitle"
                        style="@style/Style.WaterMonitor.SensorTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/sensor_tds"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/imgTdsIcon" />

                    <ImageView
                        android:id="@+id/imgTdsIcon"
                        android:layout_width="@dimen/sensor_icon_size"
                        android:layout_height="@dimen/sensor_icon_size"
                        android:src="@drawable/ic_tds_particles"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTdsValue"
                        style="@style/Style.WaterMonitor.SensorValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="150"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTdsTitle"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvTdsUnit"
                        style="@style/Style.WaterMonitor.SensorUnit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/unit_ppm"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTdsValue" />

                    <TextView
                        android:id="@+id/tvTdsStatus"
                        style="@style/Style.WaterMonitor.StatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Status: Excellent"
                        android:textColor="@color/status_green"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTdsUnit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Turbidity Sensor Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTurbidity"
                style="@style/Style.WaterMonitor.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_white_border"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/tvTurbidityTitle"
                        style="@style/Style.WaterMonitor.SensorTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/sensor_turbidity"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/imgTurbidityIcon" />

                    <ImageView
                        android:id="@+id/imgTurbidityIcon"
                        android:layout_width="@dimen/sensor_icon_size"
                        android:layout_height="@dimen/sensor_icon_size"
                        android:src="@drawable/ic_turbidity_drop"
                        android:layout_marginEnd="4dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTurbidityValue"
                        style="@style/Style.WaterMonitor.SensorValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="1.5"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTurbidityTitle"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvTurbidityUnit"
                        style="@style/Style.WaterMonitor.SensorUnit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/unit_ntu"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTurbidityValue" />

                    <TextView
                        android:id="@+id/tvTurbidityStatus"
                        style="@style/Style.WaterMonitor.StatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Status: Clear"
                        android:textColor="@color/status_green"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTurbidityUnit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
