<?xml version="1.0" encoding="utf-8"?>
<!-- Turbidity sensor — water drop with ripple rings -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="40dp"
    android:height="40dp"
    android:viewportWidth="40"
    android:viewportHeight="40">

    <!-- Water drop body (shifted 2 units up to give ripple rings room at bottom) -->
    <path
        android:pathData="M20,2 C20,2 8,16 8,23 C8,30 13.4,35 20,35 C26.6,35 32,30 32,23 C32,16 20,2 20,2 Z"
        android:fillColor="#804DB8C8"
        android:strokeColor="#0D7A8A"
        android:strokeWidth="1.5" />

    <!-- Inner highlight on drop -->
    <path
        android:pathData="M14,18 C14,18 11,24 11,26 C11,28 12,29 13,28"
        android:fillColor="#00000000"
        android:strokeColor="#A8E6EF"
        android:strokeWidth="2"
        android:strokeLineCap="round" />

    <!-- Ripple ring 1 (small, close) -->
    <path
        android:pathData="M14,36 Q20,33 26,36"
        android:fillColor="#00000000"
        android:strokeColor="#4DB8C8"
        android:strokeWidth="1.5"
        android:strokeLineCap="round" />

    <!-- Ripple ring 2 (medium) -->
    <path
        android:pathData="M10,37.5 Q20,34 30,37.5"
        android:fillColor="#00000000"
        android:strokeColor="#804DB8C8"
        android:strokeWidth="1"
        android:strokeLineCap="round" />

    <!-- Turbidity particles inside drop -->
    <path android:pathData="M17,22 m-1.2,0 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0" android:fillColor="#40FFFFFF" />
    <path android:pathData="M22,20 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0" android:fillColor="#40FFFFFF" />
    <path android:pathData="M20,26 m-0.8,0 a0.8,0.8 0 1,0 1.6,0 a0.8,0.8 0 1,0 -1.6,0" android:fillColor="#40FFFFFF" />
</vector>
